---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import ThemeToggle from '../components/ThemeToggle.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const isoDate = (d: Date) => d.toISOString().slice(0, 10);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			.intro {
				display: flex;
				align-items: center;
				gap: 1.75rem;
				margin-top: 2.5rem;
				margin-bottom: 3rem;
			}
			.intro img {
				width: 180px;
				height: 180px;
				border-radius: 50%;
				flex-shrink: 0;
			}
			.intro p {
				margin: 0;
			}
			.intro a {
				color: var(--color-muted);
				text-decoration: underline;
			}
			.intro a:hover {
				color: var(--color-heading);
			}
			@media (max-width: 640px) {
				.intro {
					flex-direction: column;
					align-items: flex-start;
					gap: 1rem;
				}
				.intro img {
					width: 140px;
					height: 140px;
				}
			}
			ul {
				list-style: none;
				margin: 0;
				padding: 0;
			}
			li {
				display: flex;
				align-items: baseline;
				gap: 1.25rem;
				margin-bottom: 0.5rem;
			}
			.date {
				color: var(--color-muted);
				font-variant-numeric: tabular-nums;
				flex-shrink: 0;
				width: 6.5rem;
			}
			.posts a {
				color: var(--color-heading);
				text-decoration: none;
				transition: color 0.15s ease;
			}
			.posts a:hover {
				color: var(--color-muted);
			}
			@media (max-width: 640px) {
				li {
					flex-direction: column;
					gap: 0.15rem;
					margin-bottom: 1rem;
				}
				.date {
					width: auto;
					font-size: 0.875rem;
				}
			}
		</style>
	</head>
	<body>
		<main>
			<ThemeToggle />
			<section class="intro">
				<img src="/profilePicture.png" alt="Johannes Krabbe" width="180" height="180" />
				<p>
					Hi, I'm Johannes, a Software Engineer based in Berlin with a passion for building
					cool products. In 2025 I finished up my Bachelor's degree at <a
						href="https://code.berlin">The Code University of Applied Sciences</a
					> in Berlin and am currently working as a Software Engineer at <a
						href="https://neotaste.com">NeoTaste</a
					>. Feel free to reach out to me, I'm always happy to meet new people :)
				</p>
			</section>
			<ul class="posts">
				{
					posts.map((post) => (
						<li>
							<time class="date" datetime={post.data.pubDate.toISOString()}>
								{isoDate(post.data.pubDate)}
							</time>
							<a href={`/${post.data.slug}/`}>{post.data.title}</a>
						</li>
					))
				}
			</ul>
		</main>
		<Footer />
	</body>
</html>
